{
    "interface_version": 2,
    "name": "MaaNotServiceRegion",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "",
    "license": "",
    "welcome": "首次使用！欢迎使用 MAA!",
    "github": "",
    "version": "v0.0.3",
    "resource": [
        {
            "name": "MGG",
            "controller": [
                "抹布",
                "安卓端"
            ],
            "path": [
                "./resource",
                "./resource_mgg"
            ]
        },
        {
            "name": "邪神戦記ルルイエ少女隊X",
            "controller": [
                "邪神",
                "安卓端"
            ],
            "path": [
                "./resource",
                "./resource_rlyeh"
            ]
        },
        {
            "name": "天使连接",
            "controller": [
                "天使",
                "安卓端"
            ],
            "path": [
                "./resource",
                "./resource_angelr"
            ]
        },
        {
            "name": "twinkle",
            "controller": [
                "twinkle",
                "安卓端"
            ],
            "path": [
                "./resource",
                "./resource_tsk"
            ]
        },
        {
            "name": "Techcronoss",
            "controller": [
                "铁扣大乱斗",
                "安卓端"
            ],
            "path": [
                "./resource",
                "./resource_tech"
            ]
        }
    ],
    "controller": [
        {
            "name": "抹布",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "^マブラヴ・ガールズガーデンX$",
                "screencap": "FramePool",
                "mouse": "LegacyEvent",
                "keyboard": "LegacyEvent"
            }
        },
        {
            "name": "铁扣大乱斗",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "テクロノス",
                "screencap": "FramePool",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "SendMessageWithCursorPos"
            }
        },
        {
            "name": "邪神",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "^邪神戦記ルルイエ少女隊X$",
                "screencap": "PrintWindow",
                "mouse": "LegacyEvent",
                "keyboard": "LegacyEvent"
            }
        },
        {
            "name": "天使",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "^エンジェリックリンク",
                "screencap": "PrintWindow",
                "mouse": "SendMessage",
                "keyboard": "SendMessage"
            }
        },
        {
            "name": "twinkle",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "twinkle_starknightsX",
                "screencap": "FramePool",
                "mouse": "LegacyEvent",
                "keyboard": "LegacyEvent"
            }
        },
        {
            "name": "安卓端",
            "type": "Adb"
        }
    ],
    "task": [],
    "import": [
        "./interface_rlyeh.json",
        "./interface_mgg.json",
        "./interface_angelr.json",
        "./interface_tsk.json",
        "./interface_tech.json"
    ]
}